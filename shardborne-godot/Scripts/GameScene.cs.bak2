            var vsBg = new ColorRect();
            vsBg.Color = new Color(0.06f, 0.07f, 0.09f, 0.97f);
            vsBg.SetAnchorsPreset(LayoutPreset.FullRect);
            _victorySelectPanel.AddChild(vsBg);

            var vsTitle = new Label { Text = "SELECT VICTORY CONDITION" };
            vsTitle.AddThemeFontSizeOverride("font_size", 22);
            vsTitle.HorizontalAlignment = HorizontalAlignment.Center;
            _victorySelectPanel.AddChild(vsTitle);

            var modes = new (VictoryMode mode, string label, string desc)[]
            {
                (VictoryMode.Annihilation, "ANNIHILATION", "Destroy enemy commander or all units"),
                (VictoryMode.Attrition, "ATTRITION", "Most VP from kills after max turns (6 turns)"),
                (VictoryMode.ObjectiveControl, "OBJECTIVE CONTROL", "Hold 3 objectives, score VP each turn"),
                (VictoryMode.KingOfTheHill, "KING OF THE HILL", "Hold center objective, score VP each turn"),
            };

            foreach (var (mode, label, desc) in modes)
            {
                var m = mode;
                var btn = new Button { Text = label + "\n" + desc };
                btn.CustomMinimumSize = new Vector2(500, 52);
                btn.Pressed += () => OnVictoryPicked(m);
                _victorySelectPanel.AddChild(btn);
            }
        }
