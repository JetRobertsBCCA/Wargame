            _logLabel.Position = new Vector2(BoardLeft, BoardTop + BoardH + 26);
            _logLabel.Size = new Vector2(BoardW, 800 - (BoardTop + BoardH + 28));
            _logLabel.AddThemeFontSizeOverride("normal_font_size", 11);
            AddChild(_logLabel);

            // Right-side buttons (below the card area)
            int btnY = 650;
            _endPhaseBtn = new Button { Text = "End Phase" };
            _endPhaseBtn.Position = new Vector2(CardPanelX, btnY);
            _endPhaseBtn.Size = new Vector2(CardPanelW / 2 - 4, 38);
            _endPhaseBtn.Pressed += OnEndPhase;
            _endPhaseBtn.Visible = false;
            AddChild(_endPhaseBtn);

            _endTurnBtn = new Button { Text = "End Turn" };
            _endTurnBtn.Position = new Vector2(CardPanelX + CardPanelW / 2 + 4, btnY);
            _endTurnBtn.Size = new Vector2(CardPanelW / 2 - 4, 38);
            _endTurnBtn.Pressed += OnEndTurn;
            _endTurnBtn.Visible = false;
