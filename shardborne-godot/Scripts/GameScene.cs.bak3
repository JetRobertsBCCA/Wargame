        //  Tabletop palette 
        static readonly Color TableFelt   = new(0.12f, 0.15f, 0.10f);
        static readonly Color CellLight   = new(0.20f, 0.22f, 0.18f);
        static readonly Color CellDark    = new(0.17f, 0.19f, 0.15f);
        static readonly Color GridLine    = new(0.28f, 0.30f, 0.25f, 0.7f);
        static readonly Color DeployBlue  = new(0.2f, 0.35f, 0.55f, 0.18f);
        static readonly Color DeployRed   = new(0.55f, 0.2f, 0.2f, 0.18f);
        static readonly Color MoveGreen   = new(0.1f, 0.75f, 0.2f, 0.3f);
        static readonly Color ChargeOrange= new(1f, 0.55f, 0.1f, 0.35f);
        static readonly Color AttackRed   = new(0.9f, 0.1f, 0.1f, 0.3f);
        static readonly Color EngageRing  = new(1f, 0.45f, 0f);
        static readonly Color SelectRing  = new(1f, 1f, 0.3f);
        static readonly Color ObjGold     = new(1f, 0.85f, 0.15f);
        static readonly Color CardBg      = new(0.10f, 0.11f, 0.13f, 0.95f);
        static readonly Color CardBorder  = new(0.45f, 0.42f, 0.35f);
        static readonly Color DiceBg      = new(0.08f, 0.08f, 0.06f, 0.9f);

        // 
        //  LIFECYCLE
        // 

        public override void _Ready()
        {
            var projectRoot = ProjectSettings.GlobalizePath("res://");
            var repoRoot = Path.GetFullPath(Path.Combine(projectRoot, ".."));
            _data = DataLoader.LoadFromRepo(repoRoot);
            MouseFilter = MouseFilterEnum.Stop;
            BuildUI();
            ShowFactionSelect();
        }

        public override void _Process(double delta)
        {
            // Dice tray fade
            if (_diceShowTimer > 0) { _diceShowTimer -= (float)delta; QueueRedraw(); }

            // AI action queue
            if (_aiProcessing)
            {
                _aiTimer -= (float)delta;
                if (_aiTimer <= 0 && _pendingAiActions.Count > 0)
                {
                    _pendingAiActions.Dequeue().Invoke();
                    RefreshHUD(); QueueRedraw();
                    _aiTimer = 0.25f;
                }
                else if (_pendingAiActions.Count == 0)
                {
                    _aiProcessing = false;
                    FinishAiTurn();
                }
            }
        }
        // 
        //  BUILD UI  (in-game HUD is minimal -- board is king)
        // 

        private void BuildUI()
        {
            // Top banner bar (thin, like a table-edge scoreboard)
            _turnBanner = new Label { Text = "SHARDBORNE" };
            _turnBanner.AddThemeFontSizeOverride("font_size", 18);
            _turnBanner.Position = new Vector2(BoardLeft, 6);
            _turnBanner.Size = new Vector2(400, 30);
            AddChild(_turnBanner);

            _phaseBanner = new Label { Text = "" };
            _phaseBanner.AddThemeFontSizeOverride("font_size", 14);
            _phaseBanner.HorizontalAlignment = HorizontalAlignment.Right;
            _phaseBanner.Position = new Vector2(BoardLeft + BoardW - 400, 6);
            _phaseBanner.Size = new Vector2(400, 30);
            AddChild(_phaseBanner);

            // Instructions (below board)
            _instructionLabel = new Label { Text = "" };
            _instructionLabel.AddThemeFontSizeOverride("font_size", 12);
            _instructionLabel.AutowrapMode = TextServer.AutowrapMode.WordSmart;
            _instructionLabel.Position = new Vector2(BoardLeft, BoardTop + BoardH + 4);
            _instructionLabel.Size = new Vector2(BoardW, 22);
            AddChild(_instructionLabel);

            // Log (small, at bottom)
            _logLabel = new RichTextLabel();
            _logLabel.BbcodeEnabled = true;
            _logLabel.ScrollActive = true;
