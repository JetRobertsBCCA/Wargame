            _backBtn.Visible = false;
            AddChild(_backBtn);

            _playAgainBtn = new Button { Text = "Play Again" };
            _playAgainBtn.Position = new Vector2(CardPanelX + CardPanelW / 2 + 4, btnY + 44);
            _playAgainBtn.Size = new Vector2(CardPanelW / 2 - 4, 32);
            _playAgainBtn.Pressed += OnPlayAgain;
            _playAgainBtn.Visible = false;
            AddChild(_playAgainBtn);

            BuildFactionSelectPanel();
